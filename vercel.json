{
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/$1" },
    { "source": "/(.*)", "destination": "/index.html" }
  ],
  "crons": [
    {
      "path": "/api/cron/timesheet-reminders",
      "schedule": "0 9 * * 1"
    },
    {
      "path": "/api/cron/project-alerts",
      "schedule": "0 8 * * *"
    },
    {
      "path": "/api/cron/collab-reminders",
      "schedule": "0 9 * * *"
    }
  ]
}
