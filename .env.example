# ──────────────────────────────────────────────────────────────────────
# Client-side (Vite — must be VITE_* prefixed to be exposed to the browser)
# ──────────────────────────────────────────────────────────────────────
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# Optional client-side integrations
# VITE_SENTRY_DSN=
# VITE_STRIPE_PUBLISHABLE_KEY=
# VITE_APP_URL=https://app.grantlume.com

# ──────────────────────────────────────────────────────────────────────
# Server-side (serverless functions under /api — never exposed to the browser)
# ──────────────────────────────────────────────────────────────────────

# Supabase (server uses service role for privileged reads/writes)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=service-role-key-here

# Claude AI (AI-assisted import + grant parsing)
CLAUDE_API_KEY=sk-ant-...

# Transactional email (Resend)
RESEND_API_KEY=re_...
EMAIL_FROM="GrantLume <no-reply@your-domain.com>"

# ──────────────────────────────────────────────────────────────────────
# REQUIRED FOR SECURITY — the corresponding handlers now refuse to run
# if these are missing. Configure before deploying.
# ──────────────────────────────────────────────────────────────────────

# Vercel Cron authentication. Vercel automatically attaches
#   Authorization: Bearer $CRON_SECRET
# to scheduled cron requests when this env var is present.
# Generate with: openssl rand -hex 32
CRON_SECRET=

# Stripe webhook signature verification. Find in the Stripe dashboard
# under Developers → Webhooks → your endpoint → "Signing secret".
STRIPE_WEBHOOK_SECRET=

# Stripe API key (server side; distinct from VITE_STRIPE_PUBLISHABLE_KEY)
STRIPE_SECRET_KEY=

# DocuSign Connect webhook HMAC key. Configured in the DocuSign admin as
# "Connect HMAC". Must match what DocuSign uses to sign webhook payloads.
DOCUSIGN_CONNECT_HMAC_KEY=

# DocuSign API credentials (if using the signing integration)
# DOCUSIGN_INTEGRATION_KEY=
# DOCUSIGN_USER_ID=
# DOCUSIGN_ACCOUNT_ID=
# DOCUSIGN_RSA_PRIVATE_KEY=
# DOCUSIGN_BASE_URL=https://demo.docusign.net/restapi
# DOCUSIGN_OAUTH_BASE_URL=account-d.docusign.com
